// Rest Digital - SaaS для заведений общепита
// Multi-tenant архитектура: каждая бизнес-сущность содержит tenantId

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// LEVEL 3: SUPERADMIN & MULTI-TENANCY CORE
// ==========================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // URL-friendly идентификатор (например, "coffee-shop")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings       TenantSettings?
  employees      Employee[]
  categories     Category[]
  products       Product[]
  customers      Customer[]
  orders         Order[]
  reviews        Review[]
  stories        Story[]
  menuPhotos    MenuPhoto[]
  forYouProducts ForYouProduct[]
  bindTokens  BindToken[]
  mailings    Mailing[]
}

model TenantSettings {
  id     String @id @default(uuid())
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String @unique

  // Брендинг (конструктор)
  logoUrl        String?
  coverUrl       String?  // Баннер на главном экране
  faviconUrl     String?
  appName        String?  // Fallback, если нет логотипа

  // Цветовая схема
  primaryColor   String   @default("#000000")
  secondaryColor String   @default("#FFFFFF")
  theme          String   @default("light") // "light" | "dark"

  // Типографика (Inter, Roboto, Montserrat, Playfair)
  fontFamily String @default("Inter")

  // Главный экран: какие блоки показывать
  showStories   Boolean @default(true)
  showLoyalty   Boolean @default(true)
  showPopular   Boolean @default(true)
  menuLayout    String  @default("grid") // "grid" | "list" | "carousel"

  // Формы элементов (px)
  borderRadius  Int     @default(8) // 0 = острые, 8 = скругленные, 9999 = круглые

  // Интеграции
  iikoApiKey      String?
  rkeeperApiKey   String?
  yandexMetricaId String?

  // Источники данных / режимы интеграций
  menuSource   String @default("pos") // "pos" | "excel"
  posProvider  String @default("none") // "none" | "iiko" | "rkeeper"

  // iiko Cloud API (официальная интеграция: https://ru.iiko.help)
  iikoApiLogin         String?  // API-ключ из «Настройки Cloud API» в iikoWeb
  iikoOrganizationId   String?  // UUID организации
  iikoTerminalGroupId  String?  // UUID терминальной группы
  iikoOrderTypeId      String?  // UUID типа заказа (legacy; используем как fallback)
  iikoOrderTypeIdDelivery String? // UUID типа заказа для DELIVERY
  iikoOrderTypeIdPickup   String? // UUID типа заказа для PICKUP
  iikoOrderTypeIdDineIn   String? // UUID типа заказа для DINE_IN
  iikoPaymentTypeId    String?  // UUID способа оплаты
  iikoWebhookSecret    String?  // Секрет для проверки вебхуков (опционально)
  iikoExternalMenuId   String?  // UUID внешнего меню iiko (основной источник синхронизации меню)
  iikoExternalMenuPriceCategoryId String?  // UUID категории цен (опционально)

  // Мессенджеры (включённые платформы для определения пользователя)
  messengerTelegram Boolean @default(true)
  messengerVk       Boolean @default(true)
  messengerMax      Boolean @default(true)
  messengerTelegramBotId String?
  messengerTelegramAppId String?
  messengerMaxBotId      String?
  messengerMaxAppId      String?
  messengerVkGroupToken  String?
  messengerVkAppId       String?

  // Бонусная карта: градиент (цвета через запятую, opacity 0-100, тип linear/radial)
  loyaltyCardGradientColors  String?  // "#hex1,#hex2,..."
  loyaltyCardGradientOpacity Int      @default(100)
  loyaltyCardGradientType    String   @default("linear") // "linear" | "radial"

  // Лояльность: points = баллы+кэшбек, stamps = закрашенные кружки
  loyaltyType        String  @default("points") // "points" | "stamps"
  loyaltyStampGoal   Int     @default(6)
  loyaltyCashbackPct Decimal @default(5) @db.Decimal(5, 2)
  // Реферальная программа: фиксированные бонусы за приглашение (обоим)
  referralBonusPoints Decimal @default(0) @db.Decimal(10, 2)
  referralBonusStamps Int     @default(0)

  // Лояльность: как заведение взаимодействует с бонусной картой гостя
  loyaltyInteraction String @default("app_only") // "app_only" | "iiko" | "rkeeper"

  // Вкладка «Общая информация»
  infoAddress      String?
  infoHours        String?
  infoPhone        String?
  infoTermsUrl     String?
  infoFaqUrl       String?
  infoPartnerUrl   String?
  infoCaloriesUrl  String?
  infoContactText  String?
  infoSocialInstagram String?
  infoSocialTelegram  String?
  infoSocialVk     String?
  infoAboutText    String?

  // Программа лояльности: описание для FAQ (HTML)
  loyaltyFaqHtml   String?
  // Приглашение друзей: текст и ссылка (если пусто — текущий URL + utm_source=invite)
  inviteText       String?
  inviteLink       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Истории/акции на главном экране клиента
model Story {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(200)
  coverUrl  String?  // обложка 3:4 для карточки
  mediaUrl  String   // контент: фото или видео
  mediaType String   @default("image") // "image" | "video"
  linkUrl   String?  // ссылка при клике на обложку (вместо просмотра контента)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// «Для вас» — выбранные партнёром блюда для блока после историй
model ForYouProduct {
  id        String  @id @default(uuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int     @default(0)
}

// Суперадмин (глобальный, не привязан к tenant)
model Superadmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

// ==========================================
// LEVEL 2: RESTAURANT ADMIN (Управление)
// ==========================================

model Employee {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String
  role         Role     @default(MANAGER)
  createdAt    DateTime @default(now())

  @@unique([tenantId, email])
}

enum Role {
  OWNER
  MANAGER
  CHEF
  COURIER
}

// ==========================================
// LEVEL 1 & 2: MENU & CATALOG
// ==========================================

model Category {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  imageUrl    String?
  isActive    Boolean  @default(true)
  isPublished Boolean @default(true)  // draft: false, published: true
  products    Product[]
}

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name         String   @db.VarChar(255)
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  oldPrice     Decimal? @db.Decimal(10, 2)
  imageUrl     String?
  weight       String?  // "300 г"
  volume       String?  // "0.5 л"
  composition  String?
  allergens    String?
  calories     Int?
  protein      Decimal? @db.Decimal(10, 2) // г (Б)
  fat           Decimal? @db.Decimal(10, 2) // г (Ж)
  carbohydrates Decimal? @db.Decimal(10, 2) // г (У)
  cookingTime  Int?     // минуты
  sku          String?

  isActive     Boolean  @default(true)   // в меню
  isAvailable  Boolean  @default(true)   // можно заказать
  isPublished  Boolean  @default(true)   // draft: false, published: true
  sortOrder    Int      @default(0)

  // Ярлыки
  isSpicy      Boolean  @default(false)
  isNew        Boolean  @default(false)
  isPopular    Boolean  @default(false)
  isRecommended Boolean @default(false)
  isVegan      Boolean  @default(false)
  isVegetarian Boolean  @default(false)
  isGlutenFree Boolean  @default(false)
  isHit        Boolean  @default(false)
  isDiscounted Boolean  @default(false)

  orderItems       OrderItem[]
  modifierGroups   ModifierGroup[]
  productBadges    ProductBadgeItem[]
  forYouProductRef ForYouProduct[]

  // Связь с iiko при синхронизации меню
  iikoProductId String?  @unique
}

model MenuPhoto {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  url       String
  fileName  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductBadgeItem {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String  @db.VarChar(100)
  sortOrder Int     @default(0)
}

model ModifierGroup {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId    String

  name        String   @db.VarChar(100)
  type        String   @default("single") // "single" | "multiple" | "quantity"
  isRequired  Boolean  @default(false)
  minSelect   Int      @default(0)
  maxSelect   Int      @default(1)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  options     ModifierOption[]

  iikoProductGroupId String?  // ID группы модификаторов в iiko
}

model ModifierOption {
  id              String        @id @default(uuid())
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  tenantId        String

  name        String   @db.VarChar(100)
  priceDelta  Decimal  @default(0) @db.Decimal(10, 2)

  // Параметры блюда по размеру/варианту (например Маленькое/Среднее/Большое).
  // Нужны, чтобы хранить KBJU/время/состав для выбранной опции.
  calories     Int?
  protein      Decimal? @db.Decimal(10, 2)
  fat          Decimal? @db.Decimal(10, 2)
  carbohydrates Decimal? @db.Decimal(10, 2)
  cookingTime  Int?
  composition  String?

  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  // iiko: productId модификатора и productGroupId
  iikoProductId    String?
  iikoProductGroupId String?
}

// ==========================================
// LEVEL 1: CLIENT APP (Клиенты и Заказы)
// ==========================================

model Customer {
  id       String   @id @default(uuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone   String
  name    String?  // Имя

  lastName   String?   // Фамилия
  patronymic String?   // Отчество
  dateOfBirth DateTime? // День рождения
  email      String?   // Эл. почта
  city       String?   // Город
  consentToMailing Boolean @default(false) // Согласие на рассылку

  stamps Int     @default(0)
  points Decimal @default(0) @db.Decimal(10, 2)

  // Канал привлечения
  platform      String? // "telegram" | "vk" | "max" | "standalone"
  platformUserId String?
  // ID пользователя в каждом мессенджере (для определения аккаунта в любом канале)
  telegramUserId String?
  vkUserId       String?
  maxUserId      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmTerm       String?
  utmContent    String?

  orders Order[]
  reviews Review[]

  // Реферальная программа
  referralCode        String?   @unique
  invitedByCustomerId String?
  invitedByCustomer   Customer? @relation("CustomerInvitedBy", fields: [invitedByCustomerId], references: [id])
  invitedCustomers    Customer[] @relation("CustomerInvitedBy")

  // POS loyalty bindings (iikoCard/iikoCard5, r_keeper)
  iikoCustomerId  String? // ID гостя в iikoCard/iikoCard5
  iikoCardNumber  String? // Номер карты/идентификатор для сканера POS (будет заполняться при интеграции)

  bindTokens BindToken[]

  cartJson String? // JSON-сериализованная корзина для кросс-платформенной синхронизации

  createdAt DateTime @default(now())

  @@unique([tenantId, phone])
}

// Универсальные токены привязки аккаунта из любого мессенджера
model BindToken {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  targetPlatform String
  token          String   @unique
  expiresAt      DateTime
  usedAt         DateTime?

  createdAt DateTime @default(now())
}

model Order {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)

  status      OrderStatus @default(NEW)
  type        OrderType   @default(DELIVERY)
  totalAmount Decimal     @db.Decimal(10, 2)
  address     String?
  comment     String?
  deliveryFee Decimal?    @db.Decimal(10, 2)

  // Канал привлечения
  platform    String? // "telegram" | "vk" | "max" | "standalone"
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?

  assignedCourierId String?
  iikoOrderId       String?   // ID заказа в iiko при интеграции

  // Асинхронная доставка в iiko (как в mariko: очередь + retry)
  iikoProviderStatus   String?   // pending | sent | error
  iikoProviderError    String?
  iikoProviderSyncedAt DateTime?
  iikoDispatchAttempts Int       @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items OrderItem[]
}

enum OrderStatus {
  NEW
  PREPARING
  IN_DELIVERY
  COMPLETED
  CANCELLED
}

enum OrderType {
  DELIVERY
  PICKUP
  DINE_IN
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity Int
  price    Decimal @db.Decimal(10, 2) // Фиксация цены на момент заказа
  modifiers String? // JSON: выбранные модификаторы
}

// ==========================================
// LEVEL 2: MAILINGS (Рассылки через мессенджеры)
// ==========================================

model Mailing {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String   @db.VarChar(200) // Название рассылки (для админки)
  channel   MailingChannel
  status    MailingStatus @default(DRAFT)

  // Контент рассылки (Telegram/VK/MAX Markdown)
  bodyHtml  String   @db.Text
  bodyPlain String?  @db.Text // Чистый текст (fallback)

  // Медиа-вложения (JSON массив объектов {type, url, caption?})
  mediaJson String?  @db.Text

  // Кнопки (JSON массив {label, url, type: "banner"|"section"})
  buttonsJson String? @db.Text

  // Сегментация (ссылка на сегмент)
  segmentId String?
  segment   MailingSegment? @relation(fields: [segmentId], references: [id])

  // Лимиты
  rateLimit     Int @default(50)  // Сообщений в час
  sentCount     Int @default(0)
  failedCount   Int @default(0)

  scheduledAt   DateTime? // Запланированная отправка
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs MailingLog[]
}

enum MailingChannel {
  TELEGRAM
  VK
  MAX
}

enum MailingStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  COMPLETED
  FAILED
}

model MailingSegment {
  id        String   @id @default(uuid())
  tenantId  String

  name        String @db.VarChar(200) // Название сегмента
  description String?

  // Фильтры сегментации
  ageFrom      Int? // Минимальный возраст
  ageTo        Int? // Максимальный возраст
  platforms    String? // JSON массив: ["telegram", "vk", "max"]
  avgCheckFrom Decimal? @db.Decimal(10, 2) // Средний чек от
  avgCheckTo   Decimal? @db.Decimal(10, 2) // Средний чек до
  categoryIds  String? // JSON массив ID категорий (что чаще заказывают)

  // Лимит
  maxMessagesPerHour Int @default(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mailings Mailing[]
}

model MailingLog {
  id        String   @id @default(uuid())
  mailingId String
  mailing   Mailing  @relation(fields: [mailingId], references: [id], onDelete: Cascade)

  customerId   String
  channel      MailingChannel
  status       MailingLogStatus @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime @default(now())
}

enum MailingLogStatus {
  PENDING
  SENT
  FAILED
}

// ==========================================
// AI MODULE: REVIEWS & FEEDBACK
// ==========================================

model Review {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  rating       Int
  text         String?

  aiTags       String?
  aiDraftReply String?

  createdAt DateTime @default(now())
}
