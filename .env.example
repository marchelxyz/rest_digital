# PostgreSQL (Railway добавляет DATABASE_URL автоматически)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Superadmin (используется в db:seed)
SUPERADMIN_EMAIL="admin@rest.digital"
SUPERADMIN_PASSWORD="admin123"

# AI-модуль (опционально)
OPENAI_API_KEY="sk-..."

# Yandex Object Storage (S3) — логотипы, обложки, изображения товаров
YANDEX_S3_BUCKET=""
YANDEX_S3_ACCESS_KEY_ID=""
YANDEX_S3_SECRET_ACCESS_KEY=""
YANDEX_S3_REGION="ru-central1"
YANDEX_S3_ENDPOINT="https://storage.yandexcloud.net"
# Публичный URL бакета (если включён публичный доступ): https://storage.yandexcloud.net/bucket-name
YANDEX_S3_PUBLIC_URL=""

# Для локальной разработки:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rest_digital"

# iiko: повторы отправки заказов (cron). Задайте секрет и вызывайте GET /api/cron/iiko-retry по расписанию.
# CRON_SECRET=""
# IIKO_PENDING_STALE_MS=300000
# IIKO_MAX_DISPATCH_ATTEMPTS=5
# IIKO_ENQUEUE_DEDUP_WINDOW_MS=90000
# IIKO_RETRY_BATCH_LIMIT=25
